# =====================================================================
# Document Chat — Ortam Değişkenleri Şablonu
# =====================================================================
#
# Bu dosyayı kopyalayıp .env olarak kaydedin:
#   cp .env.example .env
#
# Ardından aşağıdaki değerleri kendi ayarlarınıza göre doldurun.
# =====================================================================

# ── Google API (zorunlu) ───────────────────────────────────────────
# Google AI Studio'dan API anahtarı alın:
# → https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_key_here

# ── ChromaDB Ayarları ──────────────────────────────────────────────
# Vektör veritabanı kalıcı depolama dizini
# Docker kullanıyorsanız bu değer otomatik olarak override edilir.
CHROMA_PERSIST_DIR=./chroma_db

# ── Dosya İşleme Ayarları ─────────────────────────────────────────
# Yüklenebilecek maksimum dosya boyutu (MB cinsinden)
MAX_FILE_SIZE_MB=10

# Metin parçalama (chunking) ayarları
# ~500 token ≈ 2000 karakter
CHUNK_SIZE=2000
# %20 overlap → 2000 * 0.20 = 400 karakter
CHUNK_OVERLAP=400

# ── Sunucu Ayarları ───────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
