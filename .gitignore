# =====================================================================
# Document Chat — .gitignore
# =====================================================================

# ── Ortam Değişkenleri (API anahtarları!) ──────────────────────────
.env

# ── Python ─────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
*.whl

# ── Sanal Ortam ────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── ChromaDB Verileri ──────────────────────────────────────────────
chroma_db/
chroma_data/

# ── IDE / Editör ──────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Docker ─────────────────────────────────────────────────────────
# Docker volume verileri (yerel geliştirmede oluşabilir)

# ── Log Dosyaları ──────────────────────────────────────────────────
*.log

# ── Geçici Dosyalar ───────────────────────────────────────────────
tmp/
temp/
*.tmp
